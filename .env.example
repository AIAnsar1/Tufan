APP_NAME=CyberForge
APP_VERSION=0.1.0
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=UTC

SCAN_TIMEOUT=30
SCAN_MAX_THREADS=10
SCAN_RATE_LIMIT=100

CRYPTO_ALGORITHM=AES-256-GCM
CRYPTO_KEY_LENGTH=256

LOG_LEVEL=info
LOG_CHANNEL=console
LOG_FILE=./logs/app.log

REPORT_FORMAT=json
REPORT_OUTPUT=./reports

# DATABASE_URL=postgresql://user:pass@localhost:5432/cyberforge